worker_processes 1;
daemon off;
error_log stderr warn;
pid /run/nginx-vscode.pid;

# headers_more module: allows selective Set-Cookie rewriting
load_module modules/ngx_http_headers_more_filter_module.so;

events {
    worker_connections 1024;
}

http {
    access_log off;

    # WebSocket upgrade mapping
    map $http_upgrade $connection_upgrade {
        default upgrade;
        ''      close;
    }

    server {
        listen 1337;

        # -------------------------------------------------------
        # Route /_vscode-cli/* requests back to VS Code with the
        # correct ingress base path prepended.
        #
        # Root cause: HA Supervisor strips the ingress token prefix
        # from all requests before forwarding to the add-on.  VS
        # Code registers its /_vscode-cli/ handlers (including the
        # mint-key endpoint) under the full ingress path set via
        # --server-base-path.  Without restoring that prefix, the
        # mint-key POST returns 404/503, preventing VS Code from
        # deriving its AES key for localStorage secret storage.
        #
        # The vscode-secret-key-path cookie contains the full path
        # to the mint-key endpoint.  When the add-on restarts the
        # HA ingress token rotates; VS Code sets a fresh cookie on
        # the very next response, so the browser self-heals on the
        # first page load after a restart.
        #
        # @@INGRESS@@ is substituted at container start-up by the
        # nginx-vscode/run script with $(bashio::addon.ingress_entry).
        # -------------------------------------------------------
        location /_vscode-cli/ {
            proxy_pass http://127.0.0.1:1338@@INGRESS@@/_vscode-cli/;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_buffering off;
            proxy_read_timeout 86400s;
            proxy_send_timeout 86400s;

            # Rewrite the vscode-secret-key-path cookie to always point to
            # the current ingress entry path, so it stays valid after addon
            # restarts (when the HA ingress token rotates).
            # more_set_headers rewrites only this specific cookie while leaving
            # all other Set-Cookie headers (e.g. vscode-cli-secret-half) intact.
            more_set_headers 'Set-Cookie: vscode-secret-key-path=@@INGRESS@@/_vscode-cli/mint-key; Path=/; SameSite=Strict';
        }

        location / {
            proxy_pass http://127.0.0.1:1338;
            proxy_http_version 1.1;

            # WebSocket support
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection $connection_upgrade;
            proxy_set_header Host $host;

            # Long-lived connections (terminal, extension host)
            proxy_read_timeout 86400s;
            proxy_send_timeout 86400s;

            # Stream responses (terminal output, large file transfers)
            proxy_buffering off;
        }
    }
}
