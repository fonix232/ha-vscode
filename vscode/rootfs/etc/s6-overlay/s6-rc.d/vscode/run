#!/command/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# Home Assistant Add-on: VS Code (Microsoft)
# Runs VS Code serve-web
# ==============================================================================
declare -a options
declare config_path

bashio::log.info 'Starting VS Code (Microsoft)...'

config_path="/config"
if bashio::config.has_value 'config_path'; then
    config_path=$(bashio::config 'config_path')
fi

options+=(--host 127.0.0.1)
options+=(--port 1338)
options+=(--server-data-dir "/data/vscode/server-data")
options+=(--without-connection-token)
options+=(--accept-server-license-terms)

# Set server base path for ingress support
if bashio::var.has_value "${SUPERVISOR_TOKEN:-}"; then
    options+=(--server-base-path "$(bashio::addon.ingress_entry)")
fi

# Disable telemetry
options+=(--telemetry-level off)

# Export env variables for the Home Assistant extension (if installed)
export HASS_SERVER="http://supervisor/core"
export HASS_TOKEN="${SUPERVISOR_TOKEN:-}"

# Run VS Code serve-web
cd "${config_path}" || bashio::exit.nok "Could not change working directory"
exec code --cli-data-dir "/data/vscode/cli-data" serve-web "${options[@]}"
