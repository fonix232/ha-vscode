{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "rebaseWhen": "conflicted",
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchDatasources": ["github-releases"],
      "matchPackageNames": ["microsoft/vscode"],
      "automerge": false,
      "labels": ["vscode-update"]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/vscode/Dockerfile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>.+?)\\n(?:ARG\\s+\\w+=\"?)(?<currentValue>[0-9][^\"\\s]+)"
      ],
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ]
}
